{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "paneltec",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes and capture hazard photos",
        "NSPhotoLibraryUsageDescription": "Attach site photos to reports",
        "NSFaceIDUsageDescription": "Sign in quickly with Face ID",
        "NSLocationWhenInUseUsageDescription": "Capture GPS for site sign-on"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "USE_BIOMETRIC", "USE_FINGERPRINT", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-local-authentication",
        { "faceIDPermission": "Sign in quickly with Face ID" }
      ],
      [
        "expo-location",
        { "locationWhenInUsePermission": "Capture GPS for site sign-on" }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Scan QR codes for crew sign-on" }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
