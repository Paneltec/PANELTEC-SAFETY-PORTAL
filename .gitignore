# Paneltec Civil — .gitignore (v160.0.1)
# Repo hygiene for a FARM + Expo stack.
# See https://help.github.com/articles/ignoring-files/ for docs.

# =====================================================================
# Environment / secrets — CRITICAL. Never commit these.
# =====================================================================
.env
.env.*
!.env.example
!.env.sample
*.env
!example.env
!sample.env

# Credentials, keys, tokens
*.pem
*.key
*_rsa
*_dsa
id_ecdsa*
id_ed25519*
*.p12
*.pfx
*.p8
*.mobileprovision
*.jks
*.keystore
*token.json*
*credentials.json*
*.tokens.json

# =====================================================================
# Node / Yarn / npm
# =====================================================================
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm/
.eslintcache
.stylelintcache

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# =====================================================================
# React / CRA / Next / builds
# =====================================================================
/build
build/
dist/
dist
/out/
.next/
.turbo/
next-env.d.ts
*.tsbuildinfo
/coverage
service-worker.js.map

# =====================================================================
# Expo / React Native
# =====================================================================
.expo/
.expo-shared/
mobile/.expo/
mobile/.metro-cache/
mobile/web-build/
mobile/dist/
mobile/ios/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/build/
mobile/android/app/release/
metro-cache/
/tmp/metro-*

# =====================================================================
# Python / FastAPI
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
venv/
.venv/
env/
ENV/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/
.tox/

# =====================================================================
# Data / uploads / local databases
# =====================================================================
data/
mongodb/
db-backups/
*.db
*.sqlite
*.sqlite3
dump.rdb
/app/uploads/
/app/tmp/
uploads/

# =====================================================================
# Cache / build artifacts
# =====================================================================
.cache/
.parcel-cache/
frontend/node_modules/.cache/
frontend/node_modules/.cache/default-development/*.pack
frontend/node_modules/.cache/default-development/*.pack_

# =====================================================================
# System / IDE
# =====================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.suo
*.iml
.ipynb_checkpoints/
.ac

# =====================================================================
# Archives / large binaries — never commit to a code repo
# =====================================================================
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# =====================================================================
# Deployment platforms
# =====================================================================
.vercel
.netlify/

# =====================================================================
# Development tooling
# =====================================================================
chainlit.md
.chainlit

# =====================================================================
# Emergent-specific
# =====================================================================
.emergent/
!.emergent/emergent.yml
/root/.emergent/

# =====================================================================
# Project-specific — memory / test creds
# Test credentials point at the seeded dev DB only (not production).
# Kept out of git regardless.
# =====================================================================
memory/test_credentials.md

# Android SDK bundle (if ever shipped locally)
android-sdk/

# LAN backup agent local state
scripts/paneltec_backup_state.json
scripts/*.log

# Ad-hoc data files
agenthub/agents/youtube/db
frontend/node_modules/.cache/default-development/3.pack
frontend/node_modules/.cache/default-development/18.pack
frontend/node_modules/.cache/default-development/27.pack
frontend/node_modules/.cache/default-development/35.pack
frontend/node_modules/.cache/default-development/38.pack
frontend/node_modules/.cache/default-development/17.pack_
frontend/node_modules/.cache/default-development/0.pack
frontend/node_modules/.cache/default-development/18.pack_
frontend/node_modules/.cache/default-development/11.pack
frontend/node_modules/.cache/default-development/29.pack
frontend/node_modules/.cache/default-development/37.pack
credentials.json
.credentials
frontend/node_modules/.cache/default-development/4.pack
frontend/node_modules/.cache/default-development/2.pack
frontend/node_modules/.cache/default-development/5.pack
frontend/node_modules/.cache/default-development/7.pack
frontend/node_modules/.cache/default-development/8.pack
frontend/node_modules/.cache/default-development/9.pack
frontend/node_modules/.cache/default-development/10.pack
frontend/node_modules/.cache/default-development/12.pack
